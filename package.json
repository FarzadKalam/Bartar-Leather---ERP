                    "build":  "npm run check:encoding \u0026\u0026 vite build",
                    "preview":  "vite preview",
                    "deploy:server":  "powershell -ExecutionPolicy Bypass -File .\\scripts\\deploy.ps1",
                    "deploy:server:skipinstall":  "powershell -ExecutionPolicy Bypass -File .\\scripts\\deploy.ps1 -SkipInstall",
                    "deploy:server:quick":  "powershell -ExecutionPolicy Bypass -File .\\scripts\\deploy.ps1 -SkipInstall -SkipTypecheck",
